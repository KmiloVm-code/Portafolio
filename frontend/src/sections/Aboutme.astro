---
import SectionHeader from "@/components/SectionHeader.astro";
import ArrowRight from "@/assets/svg/arrow-right.astro";
import ReadingCopy from "@/components/ReadingCopy.astro";
import Button from "@/components/Button.astro";

const techStack = [
  { name: "React", icon: "devicon-react-original", category: "frontend" },
  { name: "Node.js", icon: "devicon-nodejs-plain", category: "backend" },
  { name: "Express", icon: "devicon-express-original", category: "backend" },
  {
    name: "PostgreSQL",
    icon: "devicon-postgresql-plain",
    category: "database",
  },
  { name: "Python", icon: "devicon-python-plain", category: "backend" },
  { name: "MongoDB", icon: "devicon-mongodb-plain", category: "database" },
  { name: "MySQL", icon: "devicon-mysql-plain", category: "database" },
  {
    name: "JavaScript",
    icon: "devicon-javascript-plain",
    category: "frontend",
  },
  {
    name: "TypeScript",
    icon: "devicon-typescript-plain",
    category: "frontend",
  },
  { name: "HTML5/CSS", icon: "devicon-html5-plain", category: "frontend" },
  { name: "GraphQL", icon: "devicon-graphql-plain", category: "backend" },
  { name: "MCP", icon: "/icons/mcp.svg", category: "tools" },
  { name: "N8N", icon: "/icons/n8n.svg", category: "tools" },
  { name: "Agents / LLMs", icon: "/icons/bot.svg", category: "tools" },
  { name: "GitHub", icon: "devicon-github-plain", category: "tools" },
  { name: "AWS", icon: "devicon-amazonwebservices-plain-wordmark", category: "tools" },
  { name: "Azure", icon: "devicon-azure-plain", category: "tools" },
  { name: "Docker", icon: "devicon-docker-plain", category: "tools" },
];

const categoryOrder = ["frontend", "backend", "database", "tools"];
const categories = [...new Set(techStack.map((t) => t.category))].sort(
  (a, b) => categoryOrder.indexOf(a) - categoryOrder.indexOf(b),
);

const groupedTech = categories.reduce(
  (acc, category) => {
    acc[category] = techStack.filter((tech) => tech.category === category);
    return acc;
  },
  {} as Record<string, typeof techStack>,
);

const panelMeta = {
  frontend: { tone: "#6ff8ff" },
  backend: { tone: "#9be7ff" },
  data: { tone: "#7cf7c7" },
  tools: { tone: "#c6d7ff" },
} as const;
---

<section id="sobre-mi" class="py-16 md:py-32 bg-bg relative">
  <div class="container mx-auto px-6 md:px-12 lg:px-16 max-w-7xl z-10">
    <SectionHeader
      badge="Perfil"
      title="Acerca de mí"
      subtitle="Conoce mi enfoque técnico, mi experiencia en entornos críticos y cómo uso IA para acelerar resultados sin perder calidad."
    />

    <div class="grid grid-cols-1 md:grid-cols-2 gap-14 xl:gap-20 items-start">
      <div class="space-y-8">
        <div
          class="relative aspect-video w-full rounded-2xl overflow-hidden p-[2px] bg-[length:220%_220%] bg-[image:var(--gradient-border)] animate-[shimmer_8s_linear_infinite]"
        >
          <div class="relative h-full w-full rounded-2xl overflow-hidden bg-bg">
            <img
              class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
              src="/foto.webp"
              alt="Foto de Andrés Camilo"
              loading="lazy"
              decoding="async"
            />
          </div>
        </div>

        <div class="glass-card p-6 md:p-7 space-y-5">
          <h3 class="text-2xl md:text-3xl font-bold text-primary">
            Hola, soy Andrés Camilo
          </h3>

          <div class="space-y-4 max-w-none text-secondary">
            <ReadingCopy class="max-w-[62ch]">
              Soy Desarrollador Full Stack con experiencia en React, Node.js y
              bases de datos relacionales, con fuerte background en operación,
              observabilidad y cloud (AWS y Azure).
            </ReadingCopy>

            <ReadingCopy class="max-w-[62ch]">
              Utilizo IA como apoyo activo al desarrollo para mejorar calidad de
              código, refactorización, debugging, documentación y automatización.
            </ReadingCopy>
          </div>

          <div
            class="flex flex-col sm:flex-row sm:flex-wrap sm:items-center gap-4 pt-2"
          >
            <div
              class="rounded-xl border border-accent/30 bg-accent/10 px-4 py-3 min-w-[140px]"
            >
              <h4 class="uppercase tracking-[0.2em] text-accent mt-0">
                Experiencia
              </h4>
                <span class="flex items-baseline gap-0.5 compact-inline">
                <span
                  class="text-3xl font-extrabold text-primary"
                  id="experience-counter"
                >
                  0
                </span>
                +</span
              >
              <small class="text-xs text-secondary">Años en TI</small>
            </div>

            <Button as="a" variant="primary" href="/cv-andres-camilo.pdf" class="w-full sm:w-auto" download>
              Descargar CV
              <ArrowRight size="18" class="stroke-2" />
            </Button>
          </div>
        </div>
      </div>

      <div class="space-y-7">
        <SectionHeader
          badge="Stack"
          title="Mis habilidades técnicas"
          subtitle="Tecnologías con las que diseño, construyo y escalo productos de extremo a extremo."
          align="left"
        />

        <div class="skills-switcher glass-card p-4 md:p-5">
          <div class="skills-tabs" role="tablist" aria-label="Capacidades técnicas">
            <input id="skill-frontend" type="radio" name="skill-tabs" class="sr-only" checked />
            <label for="skill-frontend" class="skill-tab">Frontend</label>

            <input id="skill-backend" type="radio" name="skill-tabs" class="sr-only" />
            <label for="skill-backend" class="skill-tab">Backend</label>

            <input id="skill-data" type="radio" name="skill-tabs" class="sr-only" />
            <label for="skill-data" class="skill-tab">Data</label>

            <input id="skill-ops" type="radio" name="skill-tabs" class="sr-only" />
            <label for="skill-ops" class="skill-tab">Ops + AI</label>
          </div>

          <div class="mt-5 skill-panels">
            <article class="skill-panel is-active" data-panel="frontend">
              <div class="skill-panel-head">
                <div>
                  <span class="eyebrow">Core capability</span>
                  <h4>Frontend</h4>
                </div>
                <i class="devicon-react-original capability-icon" aria-hidden="true"></i>
              </div>
              <p>
                Interfaces rápidas, escalables y con foco en experiencia visual.
                Conecto diseño y funcionalidad para que la navegación se sienta sólida y moderna.
              </p>
              <div class="tech-grid">
                {groupedTech.frontend.map((tech, index) => (
                  <article class="tech-card" style={`--tech-accent:${panelMeta.frontend.tone}; --tech-delay:${index * 45}ms`}>
                    {tech.icon.startsWith("/") ? (
                      <img src={tech.icon} alt="" aria-hidden="true" class="tech-icon tech-icon-image" loading="lazy" decoding="async" />
                    ) : (
                      <i class={`tech-icon ${tech.icon}`} aria-hidden="true"></i>
                    )}
                    <div class="tech-copy">
                      <span class="tech-label">Stack</span>
                      <strong>{tech.name}</strong>
                    </div>
                  </article>
                ))}
              </div>
            </article>

            <article class="skill-panel" data-panel="backend">
              <div class="skill-panel-head">
                <div>
                  <span class="eyebrow">Core capability</span>
                  <h4>Backend</h4>
                </div>
                <i class="devicon-nodejs-plain capability-icon" aria-hidden="true"></i>
              </div>
              <p>
                APIs y lógica de negocio robusta para productos que escalan. Me
                enfoco en estructuras claras, mantenibles y listas para crecer.
              </p>
              <div class="tech-grid">
                {groupedTech.backend.map((tech, index) => (
                  <article class="tech-card" style={`--tech-accent:${panelMeta.backend.tone}; --tech-delay:${index * 45}ms`}>
                    {tech.icon.startsWith("/") ? (
                      <img src={tech.icon} alt="" aria-hidden="true" class="tech-icon tech-icon-image" loading="lazy" decoding="async" />
                    ) : (
                      <i class={`tech-icon ${tech.icon}`} aria-hidden="true"></i>
                    )}
                    <div class="tech-copy">
                      <span class="tech-label">Services</span>
                      <strong>{tech.name}</strong>
                    </div>
                  </article>
                ))}
              </div>
            </article>

            <article class="skill-panel" data-panel="data">
              <div class="skill-panel-head">
                <div>
                  <span class="eyebrow">Core capability</span>
                  <h4>Data</h4>
                </div>
                <i class="devicon-postgresql-plain capability-icon" aria-hidden="true"></i>
              </div>
              <p>
                Persistencia y modelado con bases relacionales y NoSQL. Priorizo
                consistencia, trazabilidad y estructura preparada para crecer.
              </p>
              <div class="tech-grid">
                {groupedTech.database.map((tech, index) => (
                  <article class="tech-card" style={`--tech-accent:${panelMeta.data.tone}; --tech-delay:${index * 45}ms`}>
                    {tech.icon.startsWith("/") ? (
                      <img src={tech.icon} alt="" aria-hidden="true" class="tech-icon tech-icon-image" loading="lazy" decoding="async" />
                    ) : (
                      <i class={`tech-icon ${tech.icon}`} aria-hidden="true"></i>
                    )}
                    <div class="tech-copy">
                      <span class="tech-label">Storage</span>
                      <strong>{tech.name}</strong>
                    </div>
                  </article>
                ))}
              </div>
            </article>

            <article class="skill-panel" data-panel="ops">
              <div class="skill-panel-head">
                <div>
                  <span class="eyebrow">Core capability</span>
                  <h4>Ops + AI</h4>
                </div>
                <i class="devicon-docker-plain capability-icon" aria-hidden="true"></i>
              </div>
              <p>
                Infraestructura, automatización y flujos potenciados con IA.
                Uso estas piezas para acelerar entregas sin sacrificar calidad.
              </p>
              <div class="tech-grid tech-grid-tools">
                {groupedTech.tools.map((tech, index) => (
                  <article class="tech-card" style={`--tech-accent:${panelMeta.tools.tone}; --tech-delay:${index * 45}ms`}>
                    {tech.icon.startsWith("/") ? (
                      <img src={tech.icon} alt="" aria-hidden="true" class="tech-icon tech-icon-image" loading="lazy" decoding="async" />
                    ) : (
                      <i class={`tech-icon ${tech.icon}`} aria-hidden="true"></i>
                    )}
                    <div class="tech-copy">
                      <span class="tech-label">Automation</span>
                      <strong>{tech.name}</strong>
                    </div>
                  </article>
                ))}
              </div>
            </article>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .skills-switcher {
    position: relative;
    overflow: hidden;
  }

  .skills-tabs {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.5rem;
  }

  @media (min-width: 768px) {
    .skills-tabs {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }

  .skill-tab {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(0, 245, 255, 0.18);
    background: rgba(6, 12, 22, 0.56);
    color: #a7c4d2;
    padding: 0.7rem 0.8rem;
    border-radius: 0.95rem;
    font-size: 0.72rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    cursor: pointer;
    transition:
      transform 0.25s ease,
      border-color 0.25s ease,
      background 0.25s ease,
      color 0.25s ease;
  }

  .skill-tab:hover {
    color: #effcff;
    border-color: rgba(0, 245, 255, 0.4);
    transform: translateY(-1px);
  }

  input[name="skill-tabs"]:checked + .skill-tab {
    color: #031b22;
    background: linear-gradient(135deg, rgba(0, 245, 255, 0.96), rgba(102, 252, 255, 0.84));
    border-color: rgba(0, 245, 255, 0.8);
    box-shadow: 0 12px 24px rgba(0, 245, 255, 0.16);
  }

  .skill-panel {
    display: none;
    position: relative;
    padding: 1rem;
    border: 1px solid rgba(0, 245, 255, 0.16);
    border-radius: 1.2rem;
    background: linear-gradient(135deg, rgba(10, 17, 31, 0.92), rgba(6, 12, 22, 0.82));
  }

  .skill-panel.is-active {
    display: block;
    animation: panelFade 0.35s ease;
  }

  @media (min-width: 768px) {
    .skill-panel {
      padding: 1.25rem;
    }
  }

  .skill-panel-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .skill-panel h4 {
    font-size: clamp(1.9rem, 3.5vw, 3rem);
    line-height: 0.92;
    letter-spacing: -0.06em;
    margin-top: 0.4rem;
  }

  .skill-panel p {
    font-size: 0.98rem;
    line-height: 1.68;
    color: #c8d6df;
    max-width: 42ch;
  }

  .skill-panels {
    display: block;
  }

  .tech-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(11rem, 1fr));
    gap: 0.75rem;
    margin-top: 1rem;
  }

  .tech-grid-tools {
    grid-template-columns: repeat(auto-fit, minmax(12rem, 1fr));
  }

  .tech-card {
    position: relative;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.85rem 0.9rem;
    border-radius: 1rem;
    border: 1px solid color-mix(in srgb, var(--tech-accent) 32%, rgba(24, 65, 85, 0.95));
    background:
      linear-gradient(135deg, rgba(7, 14, 26, 0.96), rgba(10, 20, 34, 0.82)),
      radial-gradient(circle at top right, color-mix(in srgb, var(--tech-accent) 18%, transparent), transparent 58%);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.05),
      0 10px 20px rgba(0, 0, 0, 0.12);
    overflow: hidden;
    animation: techReveal 0.55s ease both;
    animation-delay: var(--tech-delay, 0ms);
  }

  .tech-card::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(140deg, rgba(255, 255, 255, 0.12), transparent 30%);
    opacity: 0.6;
    pointer-events: none;
  }

  .tech-card::after {
    content: "";
    position: absolute;
    inset: auto 0 0 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--tech-accent), transparent);
    opacity: 0.8;
    pointer-events: none;
  }

  .tech-card:hover {
    transform: translateY(-2px);
    border-color: color-mix(in srgb, var(--tech-accent) 58%, rgba(24, 65, 85, 0.95));
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.08),
      0 14px 26px rgba(0, 0, 0, 0.18),
      0 0 0 1px color-mix(in srgb, var(--tech-accent) 18%, transparent);
  }

  .tech-icon {
    flex-shrink: 0;
    font-size: 1.5rem;
    color: var(--tech-accent);
    filter: drop-shadow(0 0 10px color-mix(in srgb, var(--tech-accent) 40%, transparent));
  }

  .tech-icon-image {
    width: 1.5rem;
    height: 1.5rem;
    object-fit: contain;
  }

  .tech-copy {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.12rem;
    position: relative;
    z-index: 1;
  }

  .tech-label {
    font-size: 0.62rem;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--tech-accent) 78%, white);
  }

  .tech-copy strong {
    font-size: 0.92rem;
    line-height: 1.05;
    color: #effcff;
    word-break: break-word;
  }

  @keyframes techReveal {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes panelFade {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (min-width: 768px) {
    .tech-grid {
      grid-template-columns: repeat(auto-fit, minmax(11rem, 1fr));
    }

    .tech-grid-tools {
      grid-template-columns: repeat(auto-fit, minmax(12rem, 1fr));
    }
  }

  @media (max-width: 430px) {
    .tech-grid {
      grid-template-columns: 1fr;
    }

    .tech-card {
      padding: 0.8rem;
    }

    .tech-copy strong {
      font-size: 0.88rem;
    }

  }

  .capability-icon {
    font-size: 1.85rem;
    color: #effcff;
    filter: drop-shadow(0 0 12px rgba(0, 245, 255, 0.45));
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: #78f8ff;
    font-weight: 700;
  }

</style>

<script>
  function animateCounter() {
    const el = document.getElementById("experience-counter");
    if (!el || el.dataset.done === "true") return;

    const target = 8;
    let current = 0;
    const duration = 1200;
    const stepMs = 70;
    const increment = Math.max(1, Math.ceil(target / (duration / stepMs)));

    const interval = window.setInterval(() => {
      current += increment;
      if (current >= target) {
        current = target;
        window.clearInterval(interval);
        el.dataset.done = "true";
      }
      el.textContent = `${current}`;
    }, stepMs);
  }

  document.addEventListener("astro:page-load", animateCounter);

  document.addEventListener("astro:page-load", () => {
    const tabs = document.querySelectorAll<HTMLInputElement>('input[name="skill-tabs"]');
    const panels = document.querySelectorAll<HTMLElement>("[data-panel]");

    const syncPanels = () => {
      const active = document.querySelector<HTMLInputElement>('input[name="skill-tabs"]:checked');
      const activeId = active?.id.replace("skill-", "");

      panels.forEach((panel) => {
        const isActive = panel.getAttribute("data-panel") === activeId;
        panel.classList.toggle("is-active", isActive);
      });
    };

    tabs.forEach((tab) => tab.addEventListener("change", syncPanels));
    syncPanels();
  });
</script>
