---
const items = [
  { name: "Sobre mí", section: "sobre-mi" },
  { name: "Experiencia", section: "experiencia" },
  { name: "Proyectos", section: "proyectos" },
  { name: "Estudios", section: "studies" },
  { name: "Contacto", section: "contacto" },
];
---

<header class="fixed top-0 left-0 w-full z-30 px-4 md:px-8 lg:px-10 pt-3">
  <div class="mx-auto max-w-7xl">
    <div class="glass-card border-accent/20 px-4 md:px-6 py-3 md:py-4">
      <div class="flex items-center justify-between gap-4">
        <a
          href="/"
          id="logo"
          class="text-base md:text-xl font-bold tracking-tight text-primary"
          data-section="hero"
        >
          Andrés <span class="text-shimmer">Camilo</span>
        </a>

        <button
          id="mobile-menu-button"
          type="button"
          class="md:hidden inline-flex h-10 w-10 items-center justify-center rounded-full border border-border bg-bg/80 text-primary"
          aria-label="Abrir menú"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-5 w-5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 6h16M4 12h16M4 18h16"
            ></path>
          </svg>
        </button>

        <nav class="hidden md:flex items-center gap-2" aria-label="Principal">
          {
            items.map((item) => (
              <a
                href="/"
                data-section={item.section}
                class="nav-item relative px-3 py-2 text-sm font-medium text-secondary transition-colors duration-300 hover:text-primary"
              >
                <span class="relative z-10">{item.name}</span>
                <span class="nav-dot" aria-hidden="true"></span>
              </a>
            ))
          }
        </nav>
      </div>
    </div>
  </div>

  <div
    id="mobile-menu-overlay"
    class="fixed inset-0 bg-black/45 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-300 md:hidden z-40"
  ></div>
  <nav
    id="mobile-menu"
    class="fixed top-0 right-0 h-dvh w-[min(84vw,320px)] bg-bg-alt/95 border-l border-accent/25 shadow-2xl p-6 sm:p-8 pt-20 flex flex-col gap-2 sm:gap-3 translate-x-full transition-transform duration-300 md:hidden z-50"
    aria-label="Principal móvil"
  >
    {
      items.map((item) => (
        <a
          href="/"
          data-section={item.section}
          class="nav-item block rounded-xl px-4 py-3 text-base font-medium text-secondary hover:text-primary hover:bg-card/60 transition-all duration-300"
        >
          {item.name}
        </a>
      ))
    }
  </nav>

  <div class="scroll-progress" id="scroll-progress" aria-hidden="true"></div>
</header>

<style>
  .scroll-progress {
    position: fixed;
    top: 0;
    left: 0;
    width: 0;
    height: 2px;
    z-index: 35;
    background: var(--gradient-primary);
    box-shadow: 0 0 20px rgba(0, 245, 255, 0.6);
    transition: width 0.1s linear;
  }

  .nav-item {
    isolation: isolate;
    position: relative;
  }

  .nav-dot {
    display: none;
  }

  .nav-item.is-active .nav-dot {
    transform: translateY(-50%) scale(1);
    box-shadow: 0 0 10px rgba(121, 246, 255, 0.7);
  }

  .nav-item.is-active {
    color: #ecfeff;
  }

  @media (min-width: 768px) {
    .nav-item::after {
      content: "";
      position: absolute;
      left: 0.75rem;
      right: 0.75rem;
      bottom: 0.4rem;
      height: 2px;
      background: var(--gradient-primary);
      transform: scaleX(0);
      transform-origin: left;
      transition: transform 0.3s ease;
    }

    .nav-item:hover::after {
      transform: scaleX(1);
    }

    .nav-dot {
      display: block;
      width: 0.34rem;
      height: 0.34rem;
      border-radius: 999px;
      background: #79f6ff;
      position: absolute;
      left: 0.15rem;
      top: 50%;
      transform: translateY(-50%) scale(0);
      transition: transform 0.25s ease;
    }

    .nav-item.is-active::after {
      transform: scaleX(1);
    }
  }
</style>

<script>
  import { navigate } from "astro:transitions/client";

  document.addEventListener("astro:page-load", () => {
    const header = document.querySelector("header");
    const button = document.getElementById("mobile-menu-button");
    const mobileMenu = document.getElementById("mobile-menu");
    const overlay = document.getElementById("mobile-menu-overlay");
    const progress = document.getElementById("scroll-progress");
    const navItems = document.querySelectorAll(".nav-item");
    const logo = document.getElementById("logo");

    const sectionIds = ["hero", "sobre-mi", "experiencia", "proyectos", "studies", "contacto"];

    const openMenu = () => {
      mobileMenu?.classList.remove("translate-x-full");
      overlay?.classList.remove("opacity-0", "pointer-events-none");
      header?.classList.add("is-open");
    };

    const closeMenu = () => {
      mobileMenu?.classList.add("translate-x-full");
      overlay?.classList.add("opacity-0", "pointer-events-none");
      header?.classList.remove("is-open");
    };

    const updateProgress = () => {
      if (!progress) return;
      const total = document.documentElement.scrollHeight - window.innerHeight;
      const ratio = total <= 0 ? 0 : (window.scrollY / total) * 100;
      progress.style.width = `${Math.min(100, Math.max(0, ratio))}%`;
    };

    const updateActiveNav = (sectionId: string) => {
      navItems.forEach((item) => {
        const itemSection = item.getAttribute("data-section");
        item.classList.toggle("is-active", itemSection === sectionId);
      });
    };

    const scrollToSection = (sectionId: string) => {
      const targetElement = document.getElementById(sectionId);
      if (!targetElement) return;
      targetElement.scrollIntoView({ behavior: "smooth", block: "start" });
      updateActiveNav(sectionId);
    };

    navItems.forEach((item) => {
      item.addEventListener("click", async (e) => {
        e.preventDefault();
        const sectionId = item.getAttribute("data-section");
        if (!sectionId) return;

        if (window.location.pathname === "/" || window.location.pathname === "") {
          scrollToSection(sectionId);
        } else {
          sessionStorage.removeItem("scrollToSection");
          sessionStorage.setItem("scrollToSection", sectionId);
          await navigate("/");
        }

        closeMenu();
      });
    });

    logo?.addEventListener("click", async (e) => {
      e.preventDefault();
      if (window.location.pathname === "/" || window.location.pathname === "") {
        scrollToSection("hero");
      } else {
        sessionStorage.setItem("scrollToSection", "hero");
        await navigate("/");
      }
      closeMenu();
    });

    button?.addEventListener("click", () => {
      const isClosed = mobileMenu?.classList.contains("translate-x-full");
      if (isClosed) {
        openMenu();
      } else {
        closeMenu();
      }
    });

    overlay?.addEventListener("click", closeMenu);

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) updateActiveNav(entry.target.id);
        });
      },
      { root: null, rootMargin: "-25% 0px -60% 0px", threshold: 0 }
    );

    sectionIds.forEach((id) => {
      const section = document.getElementById(id);
      if (section) observer.observe(section);
    });

    window.addEventListener("scroll", updateProgress, { passive: true });
    updateProgress();
    updateActiveNav("hero");

    document.addEventListener(
      "astro:before-swap",
      () => {
        observer.disconnect();
        window.removeEventListener("scroll", updateProgress);
      },
      { once: true }
    );
  });
</script>
