---
import Github from "@/assets/svg/github.astro";
import Linkedin from "@/assets/svg/linkedin.astro";

const navLinks = [
  { name: "Sobre mí", section: "sobre-mi" },
  { name: "Experiencia", section: "experiencia" },
  { name: "Proyectos", section: "proyectos" },
  { name: "Estudios", section: "studies" },
  { name: "Contacto", section: "contacto" },
];

const currentYear = new Date().getFullYear();
---

<footer class="border-t border-border bg-bg-elevated">
  <div class="container mx-auto px-6 md:px-12 lg:px-16 py-12 max-w-7xl">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12">
      <div>
        <a href="/" class="text-xl font-bold tracking-tight">
          Andrés <span class="text-accent">Camilo</span>
        </a>
        <p class="mt-3 text-sm text-text-secondary max-w-[28ch]">
          Desarrollador Full Stack. Construyendo experiencias web modernas y escalables.
        </p>
      </div>

      <nav aria-label="Navegación del footer">
        <h4 class="text-sm font-semibold uppercase tracking-wider text-text-tertiary mb-4">Navegación</h4>
        <ul class="space-y-2">
          {navLinks.map((link) => (
            <li>
              <a
                href="/"
                data-section={link.section}
                class="text-sm text-text-secondary hover:text-text-primary transition-colors"
              >
                {link.name}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <div>
        <h4 class="text-sm font-semibold uppercase tracking-wider text-text-tertiary mb-4">Redes</h4>
        <div class="flex gap-3">
          <a
            href="https://github.com/KmiloVm"
            target="_blank"
            rel="noopener noreferrer"
            class="w-10 h-10 flex items-center justify-center rounded-lg border border-border hover:border-border-hover hover:bg-bg-card transition-colors"
            aria-label="GitHub"
          >
            <Github size="18" class="text-text-secondary" />
          </a>
          <a
            href="https://linkedin.com/in/kmilovm"
            target="_blank"
            rel="noopener noreferrer"
            class="w-10 h-10 flex items-center justify-center rounded-lg border border-border hover:border-border-hover hover:bg-bg-card transition-colors"
            aria-label="LinkedIn"
          >
            <Linkedin size="18" class="text-text-secondary" />
          </a>
        </div>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-border flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="text-xs text-text-tertiary">
        © {currentYear} Andrés Camilo. Todos los derechos reservados.
      </p>
      <p class="text-xs text-text-tertiary">
        Hecho con Astro y Tailwind CSS
      </p>
    </div>
  </div>
</footer>

<script>
  import { navigate } from "astro:transitions/client";

  document.addEventListener("astro:page-load", () => {
    document.querySelectorAll("footer a[data-section]").forEach((anchor) => {
      anchor.addEventListener("click", async (e) => {
        e.preventDefault();
        const sectionId = anchor.getAttribute("data-section");
        if (!sectionId) return;

        if (window.location.pathname === "/" || window.location.pathname === "") {
          const target = document.getElementById(sectionId);
          if (target) {
            target.scrollIntoView({ behavior: "smooth", block: "start" });
          }
        } else {
          sessionStorage.setItem("scrollToSection", sectionId);
          await navigate("/");
        }
      });
    });
  });
</script>
