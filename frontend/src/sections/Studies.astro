---
import ExternalLink from "@/assets/svg/external-link.astro";
import BadgeCheck from "@/assets/svg/badge-check.astro";
import GraduationCap from "@/assets/svg/graduation-cap.astro";
import BookText from "@/assets/svg/book-text.astro";
import CircleCheck from "@/assets/svg/circle-check.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import { getCollection } from "astro:content";

const studiesItems = await getCollection("studies");
const coursesItems = await getCollection("courses");
const certifiedItems = await getCollection("certifications");
---

<section id="studies" class="py-16 md:py-32 bg-bg-elevated relative">
  <div
    class="container mx-auto px-6 md:px-12 lg:px-16 max-w-7xl z-10 select-none"
  >
    <SectionHeader
      badge="Learning"
      title="Formación académica y cursos"
      subtitle="Un vistazo a mi trayectoria educativa y actualización continua en tecnologías clave."
    />

    <div class="group/tabs">
      <div
        role="tablist"
        aria-label="Formación"
        class="studies-tabs px-2 py-1.5 border border-border rounded-full mb-12 mx-auto w-full max-w-2xl"
      >
        <div>
          <input
            id="tab-studies"
            type="radio"
            name="formation-tabs"
            class="sr-only"
            checked
          />
          <label
            for="tab-studies"
            role="tab"
            aria-controls="panel-studies"
            class="study-tab"
          >
            <GraduationCap size="18" />
            <span class="tab-label-full">Estudios</span>
            <span class="tab-label-short">Estudios</span>
          </label>
        </div>

        <div>
          <input
            id="tab-certifications"
            type="radio"
            name="formation-tabs"
            class="sr-only"
          />
          <label
            for="tab-certifications"
            role="tab"
            aria-controls="panel-certifications"
            class="study-tab"
          >
            <BadgeCheck size="18" />
            <span class="tab-label-full">Certificaciones</span>
            <span class="tab-label-short">Certifs</span>
          </label>
        </div>

        <div>
          <input
            id="tab-courses"
            type="radio"
            name="formation-tabs"
            class="sr-only"
          />
          <label
            for="tab-courses"
            role="tab"
            aria-controls="panel-courses"
            class="study-tab"
          >
            <BookText size="18" />
            <span class="tab-label-full">Cursos</span>
            <span class="tab-label-short">Cursos</span>
          </label>
        </div>
      </div>

      <div class="tab-panels">
        <div
          id="panel-studies"
          role="tabpanel"
          aria-labelledby="tab-studies"
          class="tab-panel hidden group-has-[#tab-studies:checked]/tabs:block"
        >
          <ul class="space-y-6">
            {
              studiesItems
                .sort((a, b) => b.data.year_start - a.data.year_start)
                .map((item) => (
                  <li class="study-card flex flex-col sm:flex-row sm:items-center rounded-2xl p-6 md:p-7 justify-between gap-4">
                    <div class="flex items-start gap-3 sm:gap-4 min-w-0">
                      <span class="icon-wrap shrink-0">
                        <GraduationCap size="24" class="text-accent" />
                      </span>
                      <div class="min-w-0 flex-1">
                        <h2 class="text-lg sm:text-xl text-text-primary font-bold mb-1 leading-tight wrap-break-word text-balance">
                          {item.data.tittle}
                        </h2>
                        <h3 class="text-sm sm:text-base font-medium text-text-secondary leading-snug wrap-break-word uppercase">
                          {item.data.university}
                        </h3>
                      </div>
                    </div>

                    <div class="flex flex-col sm:items-end gap-2 pl-0 sm:pl-0">
                      <div class="text-xs sm:text-sm font-mono font-bold text-accent tracking-[0.08em] wrap-break-word">
                        {item.data.year_start} -{" "}
                        {item.data.year_end ? item.data.year_end : "Presente"}
                      </div>
                      <div class="inline-flex w-fit items-center gap-1.5 text-xs font-bold border rounded-full px-3 py-1 bg-success-muted text-success border-success/20 tracking-[0.08em] uppercase">
                        <CircleCheck size="12" />
                        {item.data.finish ? "Graduado" : "En curso"}
                      </div>
                    </div>
                  </li>
                ))
            }
          </ul>
        </div>

        <div
          id="panel-certifications"
          role="tabpanel"
          aria-labelledby="tab-certifications"
          class="tab-panel hidden group-has-[#tab-certifications:checked]/tabs:block"
        >
          <ul class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {
              certifiedItems
                .sort((a, b) => b.data.date_issued - a.data.date_issued)
                .map((item) => (
                  <li class="study-card flex flex-col sm:flex-row rounded-2xl p-5 sm:p-6 gap-4">
                    <div class="flex items-center justify-center w-20 h-20 p-2 border border-border shrink-0 rounded-xl bg-bg-elevated">
                      <img
                        src={item.data.badge_url}
                        alt={`${item.data.title} badge`}
                        class="w-full h-full object-contain"
                        loading="lazy"
                      />
                    </div>
                    <div class="grow sm:ml-5 flex flex-col justify-center min-w-0">
                      <h2 class="text-lg sm:text-xl text-text-primary font-bold leading-tight mb-1 wrap-break-word">
                        {item.data.title}
                      </h2>
                      <h3 class="text-sm sm:text-base font-medium uppercase tracking-[0.12em] text-text-secondary mb-3">
                        {item.data.company}
                      </h3>
                      {item.data.certificate_url && (
                        <a
                          href={item.data.certificate_url}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="inline-flex items-center gap-1.5 text-sm font-bold text-accent hover:text-accent-hover transition-colors"
                        >
                          Ver certificado
                          <ExternalLink size="12" />
                        </a>
                      )}
                    </div>
                  </li>
                ))
            }
          </ul>
        </div>

        <div
          id="panel-courses"
          role="tabpanel"
          aria-labelledby="tab-courses"
          class="tab-panel hidden group-has-[#tab-courses:checked]/tabs:block"
        >
          <ul class="space-y-6">
            {
              coursesItems
                .sort((a, b) => b.data.year - a.data.year)
                .map((item) => (
                  <li class="study-card rounded-2xl p-6 md:p-7">
                    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
                      <div class="flex items-center gap-4">
                        <BookText
                          size="44"
                          class="text-accent shrink-0 bg-accent-subtle p-2.5 rounded-full"
                        />
                        <div>
                          <h2 class="text-lg sm:text-xl text-text-primary font-bold leading-tight wrap-break-word text-balance">
                            {item.data.title}
                          </h2>
                          <h3 class="text-sm sm:text-base font-medium text-text-tertiary leading-snug wrap-break-word">
                            {item.data.university}
                          </h3>
                        </div>
                      </div>
                      <div class="flex items-center gap-4 sm:gap-5 pl-0 sm:pl-0">
                        <div class="flex flex-col items-start sm:items-end">
                          <span class="text-[11px] font-bold uppercase tracking-widest text-text-tertiary">
                            Duración
                          </span>
                          <span class="text-xs text-text-secondary">
                            {item.data.hours
                              ? `${item.data.hours} horas`
                              : "--"}
                          </span>
                        </div>
                        <div class="h-8 w-px bg-border hidden sm:block" />
                        <div class="flex flex-col items-start sm:items-end">
                          <span class="text-[11px] font-bold uppercase tracking-widest text-text-tertiary">
                            Año
                          </span>
                          <span class="text-xs text-text-secondary">
                            {item.data.year}
                          </span>
                        </div>
                      </div>
                    </div>
                  </li>
                ))
            }
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .studies-tabs {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.5rem;
    background: var(--color-bg);
  }

  .study-tab {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
    border-radius: 999px;
    border: 1px solid var(--color-border);
    width: 100%;
    min-width: 0;
    height: 44px;
    padding: 0 1rem;
    color: var(--color-text-tertiary);
    font-size: 0.76rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    transition: all 0.2s ease;
    cursor: pointer;
    background: transparent;
  }

  .study-tab svg {
    color: var(--color-text-tertiary);
    transition: color 0.2s ease;
  }

  input[id="tab-studies"]:checked + .study-tab,
  input[id="tab-certifications"]:checked + .study-tab,
  input[id="tab-courses"]:checked + .study-tab {
    color: var(--color-bg);
    border-color: var(--color-accent);
    background: var(--color-accent);
  }

  input[id="tab-studies"]:checked + .study-tab svg,
  input[id="tab-certifications"]:checked + .study-tab svg,
  input[id="tab-courses"]:checked + .study-tab svg {
    color: var(--color-bg);
  }

  .tab-label-short {
    display: none;
  }

  @media (max-width: 639px) {
    .study-tab {
      height: 42px;
      padding: 0 0.65rem;
      font-size: 0.66rem;
      letter-spacing: 0.07em;
      gap: 0.35rem;
    }

    .study-tab span {
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
      max-width: 100%;
    }
  }

  .study-tab:hover {
    color: var(--color-text-primary);
    border-color: var(--color-border-hover);
  }

  @media (max-width: 430px) {
    .study-tab {
      font-size: 0.61rem;
      letter-spacing: 0.05em;
      padding: 0 0.45rem;
      gap: 0.24rem;
    }

    .study-tab svg {
      width: 16px;
      height: 16px;
    }

    .tab-label-full {
      display: none;
    }

    .tab-label-short {
      display: inline;
    }
  }

  .tab-panel {
    animation: panelFade 0.35s ease;
  }

  .study-card {
    border: 1px solid var(--color-border);
    background: var(--color-bg-card);
    transition:
      border-color 0.2s ease,
      transform 0.2s ease,
      box-shadow 0.2s ease;
  }

  .study-card:hover {
    border-color: var(--color-border-hover);
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
  }

  .icon-wrap {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: 14px;
    background: var(--color-accent-subtle);
    border: 1px solid var(--color-border);
  }

  @keyframes panelFade {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
