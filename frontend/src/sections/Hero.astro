---
import Console from "../components/Console.astro";
import ArrowRight from "@/assets/svg/arrow-right.astro";
import BrainCircuit from "@/assets/svg/brain-circuit.astro";
import Database from "@/assets/svg/database.astro";
import Terminal from "@/assets/svg/terminal.astro";
import CodeXml from "@/assets/svg/code-xml.astro";
import Button from "../components/Button.astro";
import Pill from "../components/Pill.astro";
---

<section
  id="hero"
  class="hero relative min-h-screen flex items-center pt-28 md:pt-32 overflow-hidden"
>
  <div
    class="absolute inset-0 z-0 bg-cover bg-center bg-no-repeat opacity-55"
    style={{ backgroundImage: "url('/hero-background.webp')" }}
  >
  </div>
  <div class="hero-particles" aria-hidden="true"></div>
  <div class="hero-scan" aria-hidden="true"></div>
  <div
    class="absolute inset-0 z-0 bg-linear-to-r from-[#050a14] via-[#050a14]/82 to-[#050a14]/40"
  >
  </div>
  <div
    class="absolute inset-0 z-0 bg-linear-to-t from-[#050a14] via-transparent to-transparent"
  >
  </div>

  <div class="container mx-auto px-6 md:px-12 lg:px-16 max-w-352 relative z-10">
    <div
      class="inline-flex max-w-full items-center gap-2 rounded-full border border-success/30 bg-success-muted px-3 py-1.5 mb-6 sm:mb-7"
    >
      <span class="h-2 w-2 rounded-full bg-success pulse-opacity"></span>
      <span
        class="text-[10px] sm:text-xs uppercase tracking-[0.12em] sm:tracking-[0.2em] text-text-secondary font-semibold text-wrap"
        >Disponible para trabajar</span
      >
    </div>

    <h1
      class="max-w-[12ch] font-bold text-5xl lg:text-7xl tracking-[-0.05em] leading-[1.05] mb-2 sm:mb-3 before:content-['Andrés_'] before:text-text-primary after:content-['Vélez'] after:text-accent"
    >
    </h1>

    <h2
      id="typing-subtitle"
      class="max-w-none font-light text-text-secondary text-3xl lg:text-5xl leading-tight mb-2 sm:mb-3 typing-subtitle"
    >
      Full-Stack Developer
    </h2>

    <p
      class="mb-10 sm:mb-12 text-text-primary w-full sm:w-4/5 lg:w-[48%] max-w-[68ch] text-lg"
    >
      Desarrollo aplicaciones web escalables con React y Node.js, experiencia en
      Cloud (AWS/Azure) e IA aplicada al desarrollo para mejorar calidad y
      productividad.
    </p>

    <div
      class="flex flex-col sm:flex-row sm:items-center gap-4 sm:gap-5 mb-10 sm:mb-12"
    >
      <Button
        as="a"
        variant="line"
        href="/"
        class="w-full sm:w-auto gap-2 group"
        data-section="proyectos"
      >
        Ver Mis Proyectos
        <ArrowRight
          size="20"
          class="text-accent group-hover:translate-x-1 transition-transform duration-200"
        />
      </Button>
      <Button
        as="a"
        variant="primary"
        href="/"
        class="w-full sm:w-auto"
        data-section="contacto"
      >
        Contáctame
      </Button>
    </div>

    <div
      class="flex flex-wrap items-center gap-3 sm:gap-4 mx-auto justify-center sm:justify-start"
    >
      <Pill class="w-32 items-center justify-center">
        <CodeXml size="20" class="text-accent" />
        <span class="chip-label">Frontend</span>
      </Pill>
      <Pill class="w-32 items-center justify-center">
        <Database size="20" class="text-accent" />
        <span class="chip-label">Backend</span>
      </Pill>
      <Pill class="w-32 items-center justify-center">
        <Terminal size="20" class="text-accent" />
        <span class="chip-label">DevOps</span>
      </Pill>
      <Pill class="w-32 items-center justify-center">
        <BrainCircuit size="20" class="text-accent" />
        <span class="chip-label">AI Dev</span>
      </Pill>
    </div>

    <Console />
  </div>
</section>

<style>
  .hero-particles,
  .hero-scan {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }

  .hero-particles::before,
  .hero-particles::after {
    content: "";
    position: absolute;
    width: 380px;
    height: 380px;
    border-radius: 999px;
    background: radial-gradient(
      circle,
      rgba(89, 240, 255, 0.26),
      transparent 65%
    );
    filter: blur(3px);
    animation: blobFloat 16s ease-in-out infinite;
  }

  .hero-particles::before {
    top: 14%;
    left: 4%;
  }

  .hero-particles::after {
    bottom: 8%;
    right: 6%;
    animation-delay: 4s;
  }

  .hero-scan {
    background-image:
      radial-gradient(
        circle at 20% 25%,
        rgba(0, 245, 255, 0.14),
        transparent 30%
      ),
      radial-gradient(
        circle at 78% 70%,
        rgba(102, 252, 255, 0.11),
        transparent 34%
      );
  }

  .typing-subtitle {
    position: relative;
    display: inline-flex;
    align-items: baseline;
    white-space: nowrap;
    padding-right: 0.15em;
  }

  .typing-subtitle::after {
    content: "";
    display: inline-block;
    width: 2px;
    height: 0.92em;
    margin-left: 0.08em;
    background: #8ef8ff;
    transform: translateY(0.08em);
    animation: cursorBlink 0.9s step-end infinite;
    flex: none;
  }

  .ui-pill span {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-text-secondary);
    font-weight: 600;
  }

  @keyframes cursorBlink {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0;
    }
  }

  @keyframes blobFloat {
    0%,
    100% {
      transform: translate3d(0, 0, 0) scale(1);
    }
    50% {
      transform: translate3d(20px, -22px, 0) scale(1.1);
    }
  }

  @media (max-width: 768px) {
    .hero-particles::before,
    .hero-particles::after {
      width: 220px;
      height: 220px;
    }

    .ui-pill span {
      font-size: 0.66rem;
      letter-spacing: 0.11em;
    }
  }
</style>

<script>
  import { navigate } from "astro:transitions/client";

  function scrollToSection(sectionId: string) {
    const targetElement = document.getElementById(sectionId);
    if (targetElement) {
      targetElement.scrollIntoView({ behavior: "smooth", block: "start" });
    }
  }

  function setupHeroLinks() {
    document.querySelectorAll("a[data-section]").forEach((anchor) => {
      anchor.addEventListener("click", async (event) => {
        event.preventDefault();
        const sectionId = anchor.getAttribute("data-section");
        if (!sectionId) return;

        if (
          window.location.pathname === "/" ||
          window.location.pathname === ""
        ) {
          scrollToSection(sectionId);
        } else {
          sessionStorage.setItem("scrollToSection", sectionId);
          await navigate("/");
        }
      });
    });
  }

  function setupTypingSubtitle() {
    const el = document.getElementById("typing-subtitle");
    if (!el) return;
    const text = "Full-Stack Developer";
    el.textContent = "";
    let i = 0;

    const timer = window.setInterval(() => {
      el.textContent = text.slice(0, i + 1);
      i += 1;
      if (i >= text.length) {
        window.clearInterval(timer);
      }
    }, 60);
  }

  document.addEventListener("astro:page-load", () => {
    setupHeroLinks();
    setupTypingSubtitle();

    const sectionToScroll = sessionStorage.getItem("scrollToSection");
    if (sectionToScroll) {
      sessionStorage.removeItem("scrollToSection");
      setTimeout(() => scrollToSection(sectionToScroll), 100);
    }
  });
</script>
