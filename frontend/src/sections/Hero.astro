---
import Console from "../components/Console.astro";
import ArrowRight from "@/assets/svg/arrow-right.astro";
import BrainCircuit from "@/assets/svg/brain-circuit.astro";
import Database from "@/assets/svg/database.astro";
import Terminal from "@/assets/svg/terminal.astro";
import CodeXml from "@/assets/svg/code-xml.astro";
import Button from "@/components/Button.astro";
import Pill from "@/components/Pill.astro";
---

<section
  id="hero"
  class="hero relative min-h-screen flex items-center pt-28 md:pt-32 overflow-hidden"
>
  <div
    class="absolute inset-0 z-0 bg-cover bg-center bg-no-repeat opacity-55"
    style={{ backgroundImage: "url('/hero-background.webp')" }}
  >
  </div>
  <div class="hero-particles" aria-hidden="true"></div>
  <div class="hero-scan" aria-hidden="true"></div>
  <div
    class="absolute inset-0 z-0 bg-linear-to-r from-[#050a14] via-[#050a14]/82 to-[#050a14]/40"
  >
  </div>
  <div
    class="absolute inset-0 z-0 bg-linear-to-t from-[#050a14] via-transparent to-transparent"
  >
  </div>

  <div
    class="container mx-auto px-6 md:px-12 lg:px-16 max-w-[88rem] relative z-10"
  >
    <div
      class="inline-flex max-w-full items-center gap-2 rounded-full border border-green-400/30 bg-green-400/10 px-3 py-1.5 mb-6 sm:mb-7 pulse-glow"
    >
      <span class="h-2.5 w-2.5 rounded-full bg-green-400"></span>
      <span
        class="text-[10px] sm:text-xs uppercase tracking-[0.12em] sm:tracking-[0.2em] text-cyan-100 font-semibold text-wrap"
        >Disponible para trabajar</span
      >
    </div>

    <h1
      class="relative max-w-[12ch] font-bold tracking-[-0.07em] leading-[0.88] text-[clamp(2.5rem,6.8vw,5.6rem)] text-primary animate-fade-in-up mb-2 sm:mb-3"
    >
      <span
        class="absolute -inset-6 md:-inset-8 -z-10 blur-3xl bg-cyan-400/20 rounded-full"
      ></span>
      <span class="text-shimmer block">Andrés Camilo</span>
    </h1>

    <h2
      class="max-w-none font-light text-secondary leading-[0.95] mt-5 sm:mt-6 mb-5 sm:mb-6 text-[clamp(1.25rem,3.7vw,3.1rem)] animate-fade-in-up animate-delay-100"
    >
      <span id="typing-subtitle" class="typing-subtitle"
        >Full-Stack Developer</span
      >
    </h2>

    <p
      class="mt-1 sm:mt-2 mb-10 sm:mb-12 text-[clamp(0.98rem,1.05vw,1.12rem)] leading-[1.72] w-full sm:w-4/5 lg:w-[48%] max-w-[68ch] animate-fade-in-up animate-delay-200"
    >
      Desarrollo aplicaciones web escalables con React y Node.js, experiencia en
      Cloud (AWS/Azure) e IA aplicada al desarrollo para mejorar calidad y
      productividad.
    </p>

    <div
      class="flex flex-col sm:flex-row sm:items-center gap-4 sm:gap-5 mb-10 sm:mb-12 animate-fade-in-up animate-delay-300"
    >
      <Button as="a" variant="line" href="/" class="w-full sm:w-auto gap-2 group" data-section="proyectos">
        Ver Mis Proyectos
        <ArrowRight
          size="20"
          class="stroke-2 text-icon-secondary group-hover:text-icon group-hover:translate-x-1 transition-all duration-300"
        />
      </Button>
      <Button as="a" variant="primary" href="/" class="w-full sm:w-auto" data-section="contacto">
        Contáctame
      </Button>
    </div>

    <div
      class="flex flex-wrap items-center gap-2.5 sm:gap-3 md:gap-3.5 lg:gap-4 mx-auto justify-center sm:justify-start animate-fade-in-up animate-delay-400"
    >
      <Pill>
        <CodeXml
          size="22"
          class="text-icon-secondary drop-shadow-[0_0_12px_rgba(0,245,255,0.45)]"
        />
        <span class="chip-label">Frontend</span>
      </Pill>
      <Pill>
        <Database
          size="22"
          class="text-icon-secondary drop-shadow-[0_0_12px_rgba(0,245,255,0.45)]"
        />
        <span class="chip-label">Backend</span>
      </Pill>
      <Pill>
        <Terminal
          size="22"
          class="text-icon-secondary drop-shadow-[0_0_12px_rgba(0,245,255,0.45)]"
        />
        <span class="chip-label">DevOps</span>
      </Pill>
      <Pill>
        <BrainCircuit
          size="22"
          class="text-icon-secondary drop-shadow-[0_0_12px_rgba(0,245,255,0.45)]"
        />
        <span class="chip-label">AI Dev</span>
      </Pill>
    </div>

    <Console />
  </div>
</section>

<style>
  .hero-particles,
  .hero-scan {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }

  .hero-particles::before,
  .hero-particles::after {
    content: "";
    position: absolute;
    width: 380px;
    height: 380px;
    border-radius: 999px;
    background: radial-gradient(
      circle,
      rgba(89, 240, 255, 0.26),
      transparent 65%
    );
    filter: blur(3px);
    animation: blobFloat 16s ease-in-out infinite;
  }

  .hero-particles::before {
    top: 14%;
    left: 4%;
  }

  .hero-particles::after {
    bottom: 8%;
    right: 6%;
    animation-delay: 4s;
  }

  .hero-scan {
    background-image:
      radial-gradient(
        circle at 20% 25%,
        rgba(0, 245, 255, 0.14),
        transparent 30%
      ),
      radial-gradient(
        circle at 78% 70%,
        rgba(102, 252, 255, 0.11),
        transparent 34%
      );
  }

  .typing-subtitle {
    position: relative;
    display: inline-flex;
    align-items: baseline;
    white-space: nowrap;
    padding-right: 0.15em;
    line-height: 0.92;
  }

  .typing-subtitle::after {
    content: "";
    display: inline-block;
    width: 2px;
    height: 0.92em;
    margin-left: 0.08em;
    background: #8ef8ff;
    transform: translateY(0.08em);
    animation: cursorBlink 0.9s step-end infinite;
    flex: none;
  }

  .ui-pill span {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: #d7ebf2;
    font-weight: 600;
  }

  @keyframes cursorBlink {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0;
    }
  }

  @keyframes blobFloat {
    0%,
    100% {
      transform: translate3d(0, 0, 0) scale(1);
    }
    50% {
      transform: translate3d(20px, -22px, 0) scale(1.1);
    }
  }

  @media (max-width: 768px) {
    .hero-particles::before,
    .hero-particles::after {
      width: 220px;
      height: 220px;
    }

    .ui-pill span {
      font-size: 0.66rem;
      letter-spacing: 0.11em;
    }
  }
</style>

<script>
  import { navigate } from "astro:transitions/client";

  function scrollToSection(sectionId: string) {
    const targetElement = document.getElementById(sectionId);
    if (targetElement) {
      targetElement.scrollIntoView({ behavior: "smooth", block: "start" });
    }
  }

  function setupHeroLinks() {
    document.querySelectorAll("a[data-section]").forEach((anchor) => {
      anchor.addEventListener("click", async (event) => {
        event.preventDefault();
        const sectionId = anchor.getAttribute("data-section");
        if (!sectionId) return;

        if (
          window.location.pathname === "/" ||
          window.location.pathname === ""
        ) {
          scrollToSection(sectionId);
        } else {
          sessionStorage.setItem("scrollToSection", sectionId);
          await navigate("/");
        }
      });
    });
  }

  function setupTypingSubtitle() {
    const el = document.getElementById("typing-subtitle");
    if (!el) return;
    const text = "Full-Stack Developer";
    el.textContent = "";
    let i = 0;

    const timer = window.setInterval(() => {
      el.textContent = text.slice(0, i + 1);
      i += 1;
      if (i >= text.length) {
        window.clearInterval(timer);
      }
    }, 60);
  }

  document.addEventListener("astro:page-load", () => {
    setupHeroLinks();
    setupTypingSubtitle();

    const sectionToScroll = sessionStorage.getItem("scrollToSection");
    if (sectionToScroll) {
      sessionStorage.removeItem("scrollToSection");
      setTimeout(() => scrollToSection(sectionToScroll), 100);
    }
  });
</script>
