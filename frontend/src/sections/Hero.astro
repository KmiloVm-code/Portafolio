---
import Console from "../components/Console.astro";
import ArrowRight from "@/assets/svg/arrow-right.astro";
import BrainCircuit from "@/assets/svg/brain-circuit.astro";
import Database from "@/assets/svg/database.astro";
import Terminal from "@/assets/svg/terminal.astro";
import CodeXml from "@/assets/svg/code-xml.astro";
---

<section id="hero" class="hero relative min-h-screen flex items-center pt-28 md:pt-32 overflow-hidden">
  <div
    class="absolute inset-0 z-0 bg-cover bg-center bg-no-repeat opacity-55"
    style={{ backgroundImage: "url('/hero-background.webp')" }}
  ></div>
  <div class="hero-particles" aria-hidden="true"></div>
  <div class="hero-scan" aria-hidden="true"></div>
  <div class="absolute inset-0 z-0 bg-linear-to-r from-[#050a14] via-[#050a14]/82 to-[#050a14]/40"></div>
  <div class="absolute inset-0 z-0 bg-linear-to-t from-[#050a14] via-transparent to-transparent"></div>

  <div class="container mx-auto px-6 md:px-12 lg:px-16 max-w-7xl relative z-10">
    <div class="inline-flex max-w-full items-center gap-2 rounded-full border border-green-400/30 bg-green-400/10 px-3 py-1.5 mb-5 pulse-glow">
      <span class="h-2.5 w-2.5 rounded-full bg-green-400"></span>
      <span class="text-[10px] sm:text-xs uppercase tracking-[0.12em] sm:tracking-[0.2em] text-green-200 font-semibold text-wrap">Disponible para trabajar</span>
    </div>

    <h1 class="relative font-bold tracking-tight leading-[1.02] text-[clamp(2.3rem,6vw,4.8rem)] text-primary animate-fade-in-up">
      <span class="absolute -inset-6 md:-inset-8 -z-10 blur-3xl bg-cyan-400/20 rounded-full"></span>
      <span class="text-shimmer">Andrés Camilo</span>
    </h1>

    <h2 class="font-light text-secondary leading-snug mt-2 mb-4 text-[clamp(1.35rem,3.6vw,3rem)] animate-fade-in-up animate-delay-100">
      <span id="typing-subtitle" class="typing-subtitle">Full-Stack Developer</span>
    </h2>

    <p class="prose prose-invert mt-2 mb-8 text-[clamp(1rem,1.2vw,1.2rem)] w-full sm:w-4/5 lg:w-1/2 max-w-[65ch] animate-fade-in-up animate-delay-200">
      Desarrollo aplicaciones web escalables con React y Node.js, experiencia en
      Cloud (AWS/Azure) e IA aplicada al desarrollo para mejorar calidad y
      productividad.
    </p>

    <div class="flex flex-col sm:flex-row sm:items-center gap-4 mb-14 animate-fade-in-up animate-delay-300">
      <a
        href="/"
        data-section="proyectos"
        class="btn-line w-full sm:w-auto text-center px-6 py-3 gap-2 flex items-center justify-center font-semibold group"
      >
        Ver Mis Proyectos
        <ArrowRight
          size="20"
          class="stroke-2 text-icon-secondary group-hover:text-icon group-hover:translate-x-1 transition-all duration-300"
        />
      </a>
      <a
        href="/"
        data-section="contacto"
        class="btn-primary w-full sm:w-auto text-center px-6 py-3 font-semibold"
      >
        Contáctame
      </a>
    </div>

    <div class="flex flex-wrap items-center gap-3 sm:gap-4 md:gap-6 mx-auto justify-center sm:justify-start animate-fade-in-up animate-delay-400">
      <div class="skill-pill">
        <CodeXml size="22" class="text-icon-secondary" />
        <span>Frontend</span>
      </div>
      <div class="skill-pill">
        <Database size="22" class="text-icon-secondary" />
        <span>Backend</span>
      </div>
      <div class="skill-pill">
        <Terminal size="22" class="text-icon-secondary" />
        <span>DevOps</span>
      </div>
      <div class="skill-pill">
        <BrainCircuit size="22" class="text-icon-secondary" />
        <span>AI Dev</span>
      </div>
    </div>

    <Console />
  </div>
</section>

<style>
  .hero-particles,
  .hero-scan {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }

  .hero-particles::before,
  .hero-particles::after {
    content: "";
    position: absolute;
    width: 340px;
    height: 340px;
    border-radius: 999px;
    background: radial-gradient(circle, rgba(89, 240, 255, 0.26), transparent 65%);
    filter: blur(3px);
    animation: blobFloat 16s ease-in-out infinite;
  }

  .hero-particles::before {
    top: 14%;
    left: 8%;
  }

  .hero-particles::after {
    bottom: 8%;
    right: 12%;
    animation-delay: 4s;
  }

  .hero-scan {
    background-image: radial-gradient(circle at 20% 25%, rgba(0, 188, 212, 0.14), transparent 30%),
      radial-gradient(circle at 78% 70%, rgba(0, 188, 212, 0.11), transparent 34%);
  }

  .typing-subtitle {
    position: relative;
    display: inline-block;
  }

  .typing-subtitle::after {
    content: "";
    position: absolute;
    right: -0.2rem;
    top: 0.1em;
    width: 2px;
    height: 0.95em;
    background: #8ef8ff;
    animation: cursorBlink 0.9s step-end infinite;
  }

  .skill-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    border: 1px solid rgba(0, 188, 212, 0.35);
    background: rgba(9, 17, 31, 0.68);
    border-radius: 999px;
    padding: 0.45rem 0.75rem;
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
  }

  .skill-pill span {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: #d7ebf2;
    font-weight: 600;
  }

  .skill-pill:hover {
    transform: translateY(-3px);
    border-color: rgba(0, 188, 212, 0.7);
    box-shadow: 0 10px 24px rgba(0, 188, 212, 0.22);
  }

  @keyframes cursorBlink {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0;
    }
  }

  @keyframes blobFloat {
    0%,
    100% {
      transform: translate3d(0, 0, 0) scale(1);
    }
    50% {
      transform: translate3d(20px, -22px, 0) scale(1.1);
    }
  }

  @media (max-width: 768px) {
    .hero-particles::before,
    .hero-particles::after {
      width: 220px;
      height: 220px;
    }
  }
</style>

<script>
  import { navigate } from "astro:transitions/client";

  function scrollToSection(sectionId: string) {
    const targetElement = document.getElementById(sectionId);
    if (targetElement) {
      targetElement.scrollIntoView({ behavior: "smooth", block: "start" });
    }
  }

  function setupHeroLinks() {
    document.querySelectorAll("a[data-section]").forEach((anchor) => {
      anchor.addEventListener("click", async (event) => {
        event.preventDefault();
        const sectionId = anchor.getAttribute("data-section");
        if (!sectionId) return;

        if (window.location.pathname === "/" || window.location.pathname === "") {
          scrollToSection(sectionId);
        } else {
          sessionStorage.setItem("scrollToSection", sectionId);
          await navigate("/");
        }
      });
    });
  }

  function setupTypingSubtitle() {
    const el = document.getElementById("typing-subtitle");
    if (!el) return;
    const text = "Full-Stack Developer";
    el.textContent = "";
    let i = 0;

    const timer = window.setInterval(() => {
      el.textContent = text.slice(0, i + 1);
      i += 1;
      if (i >= text.length) {
        window.clearInterval(timer);
      }
    }, 60);
  }

  document.addEventListener("astro:page-load", () => {
    setupHeroLinks();
    setupTypingSubtitle();

    const sectionToScroll = sessionStorage.getItem("scrollToSection");
    if (sectionToScroll) {
      sessionStorage.removeItem("scrollToSection");
      setTimeout(() => scrollToSection(sectionToScroll), 100);
    }
  });
</script>
