---
import { getCollection } from "astro:content";
import SectionHeader from "@/components/SectionHeader.astro";
import ArrowRight from "@/assets/svg/arrow-right.astro";
import ReadingCopy from "@/components/ReadingCopy.astro";
import Chip from "@/components/Chip.astro";

const projectItems = await getCollection("projects");
---

<section id="proyectos" class="py-16 md:py-32 bg-bg relative">
  <div class="container mx-auto px-6 md:px-12 lg:px-16 max-w-7xl z-10">
    <SectionHeader
      badge="Work"
      title="Proyectos destacados"
      subtitle="Una selección de productos donde combiné estrategia, diseño y ejecución técnica para resolver problemas reales."
    />

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
      {
        projectItems.map((item) => {
          const { data, slug } = item;
          const { title, description, images, technologies } = data;

          return (
            <article class="project-card group rounded-2xl overflow-hidden border border-border/50 bg-card/30 backdrop-blur-sm">
              <a class="flex flex-col h-full" href={`/proyecto/${slug}`}>
                <div class="relative overflow-hidden">
                  <img
                    src={images ? images[0] : "/projects/default-project.webp"}
                    alt={title}
                    class="w-full h-52 object-cover object-top transition-transform duration-500 group-hover:scale-105"
                    transition:name={`image-${slug}`}
                    loading="lazy"
                  />

                  <div class="project-overlay absolute inset-0 hidden sm:flex items-end justify-between p-4">
                    <span class="inline-flex items-center rounded-full border border-white/35 bg-black/35 px-3 py-1 text-[11px] uppercase tracking-[0.18em] text-white">
                      Ver proyecto
                    </span>
                    <ArrowRight size="18" class="text-white" />
                  </div>
                </div>

                <div class="p-5 flex flex-col gap-4 grow">
                  <h2 transition:name={`title-${slug}`} class="text-lg sm:text-xl font-bold mb-0 break-words">{title}</h2>
                  <ReadingCopy size="sm" class="text-secondary line-clamp-4 mb-0">{description}</ReadingCopy>

                  <div class="flex flex-wrap gap-2 mt-auto">
                    {technologies.slice(0, 4).map((tech) => (
                      <Chip>{tech}</Chip>
                    ))}
                  </div>

                  <div class="project-cta text-sm font-semibold text-accent inline-flex items-center gap-2">
                    Ver proyecto
                    <ArrowRight size="12" class="transition-transform duration-300" />
                  </div>
                </div>
              </a>
            </article>
          );
        })
      }
    </div>
  </div>
</section>

<style>
  .project-card {
    position: relative;
    transition: transform 0.35s ease, border-color 0.35s ease, box-shadow 0.35s ease;
  }

  .project-card::before {
    content: "";
    position: absolute;
    inset: -1px;
    border-radius: inherit;
    background: linear-gradient(120deg, rgba(0, 245, 255, 0.72), rgba(0, 245, 255, 0.12), rgba(0, 245, 255, 0.72));
    z-index: -1;
    opacity: 0;
    transition: opacity 0.35s ease;
  }

  .project-card:hover::before {
    opacity: 1;
  }

  .project-card:hover {
    transform: translateY(-6px);
    border-color: rgba(0, 245, 255, 0.55);
    box-shadow: 0 20px 36px rgba(0, 0, 0, 0.35), 0 0 30px rgba(0, 245, 255, 0.18);
  }

  .project-overlay {
    background: linear-gradient(to top, rgba(3, 9, 19, 0.85), rgba(3, 9, 19, 0.08));
    opacity: 0;
    transition: opacity 0.35s ease;
  }

  .project-card:hover .project-overlay {
    opacity: 1;
  }

  .project-card:hover .project-cta {
    color: #e8fdff;
  }

  .project-card:hover .project-cta svg {
    transform: translateX(3px);
  }

  .project-card:hover h2 {
    color: #abf4ff;
  }
</style>
