---
import { getCollection } from "astro:content";
import Briefcase from "@/assets/svg/briefcase-business.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import ReadingCopy from "@/components/ReadingCopy.astro";

const experienceItems = await getCollection("experience");
---

<section id="experiencia" class="py-16 md:py-32 bg-bg-alt relative">
  <div class="container mx-auto px-6 md:px-12 lg:px-16 max-w-7xl z-10 select-none">
    <SectionHeader
      badge="Career"
      title="Trayectoria profesional"
      subtitle="Un recorrido por los hitos que han definido mi carrera y el impacto generado en cada etapa."
    />

    <div class="relative space-y-8">
      <div class="timeline-line absolute left-5 md:left-44 top-0 bottom-0 w-[2px]"></div>

      {
        experienceItems
          .sort((a, b) => b.data.start_date - a.data.start_date)
          .map((item) => {
            const technologies = item.data.technologies
              .split(",")
              .map((tech) => tech.trim())
              .filter(Boolean);

            return (
              <div class="relative grid grid-cols-[40px_1fr] md:grid-cols-[140px_72px_1fr] items-start group timeline-view animate-fade-in-left animate-range-entry">
                <div class="hidden md:flex justify-end pt-2.5 pr-8">
                  <span class="font-bold text-accent font-mono tracking-tighter text-right">
                    {item.data.start_date} - {item.data.end_date}
                  </span>
                </div>

                <div class="flex justify-center z-10">
                  <div class="timeline-icon w-10 h-10 flex items-center justify-center border border-border/40 rounded-full bg-bg z-10">
                    <Briefcase size="18" class="text-icon/70" />
                  </div>
                </div>

                <div class="pl-4 md:pl-10">
                  <div class="md:hidden flex items-center h-auto min-h-10 mb-4">
                    <span class="text-[11px] font-bold text-cyan-500/90 font-mono tracking-[0.1em] uppercase break-words">
                      {item.data.start_date} - {item.data.end_date}
                    </span>
                  </div>

                    <article class="experience-card p-6 rounded-2xl border border-border bg-card/30">
                    <div class="experience-layout gap-6 lg:gap-8 items-start">
                      <div class="experience-main">
                        <div class="experience-panel mb-5">
                          <h2 class="text-lg sm:text-xl font-bold mb-1 transition-colors duration-300 break-words">{item.data.title}</h2>
                          <h3 class="text-base md:text-lg font-medium text-secondary">{item.data.company}</h3>
                        </div>

                        <div class="experience-copy text-secondary/95 max-w-[52ch] lg:max-w-[56ch]">
                          {item.data.description
                            .split(/\n\s*\n/)
                            .map((paragraph, index) => (
                              <div class={`experience-paragraph experience-paragraph-${index + 1}`.trim()}>
                                <span class="experience-bullet" aria-hidden="true"></span>
                                <ReadingCopy as="p" size="sm" class="experience-paragraph-text">
                                  {paragraph}
                                </ReadingCopy>
                              </div>
                            ))}
                        </div>
                      </div>

                      <aside class="experience-aside">
                        <div class="experience-aside-block">
                          <span class="experience-aside-label">Periodo</span>
                          <span class="experience-aside-value">{item.data.start_date} - {item.data.end_date}</span>
                        </div>

                        <div class="experience-aside-block">
                          <span class="experience-aside-label">Tecnologías</span>
                          <ul class="experience-tags flex flex-wrap gap-2">
                            {technologies.map((tech) => (
                              <li class="tech-badge">{tech}</li>
                            ))}
                          </ul>
                        </div>
                      </aside>
                    </div>
                  </article>
                </div>
              </div>
            );
          })
      }
    </div>
  </div>
</section>

<style>
  .timeline-line {
    background: linear-gradient(to bottom, transparent, rgba(0, 245, 255, 0.75), transparent);
    filter: drop-shadow(0 0 12px rgba(0, 245, 255, 0.5));
  }

  .timeline-icon {
    transition: transform 0.35s ease, box-shadow 0.35s ease, border-color 0.35s ease;
  }

  .group:hover .timeline-icon {
    transform: scale(1.02);
    border-color: rgba(0, 245, 255, 0.2);
    box-shadow: 0 0 0 3px rgba(0, 245, 255, 0.04);
  }

  .experience-card {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    transition: border-color 0.3s ease, transform 0.3s ease, box-shadow 0.3s ease;
  }

  .experience-layout {
    display: grid;
  }

  @media (min-width: 1024px) {
    .experience-layout {
      grid-template-columns: minmax(0, 1fr) 10rem;
    }
  }

  .experience-aside {
    display: grid;
    gap: 0.6rem;
    padding-top: 0.15rem;
  }

  .experience-aside-block {
    display: grid;
    gap: 0.35rem;
    padding: 0.7rem 0.75rem;
    border: 1px solid rgba(0, 245, 255, 0.1);
    border-radius: 1rem;
    background: rgba(0, 245, 255, 0.025);
  }

  .experience-aside-label {
    font-size: 0.58rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(132, 253, 255, 0.7);
  }

  .experience-aside-value {
    font-family: "Satoshi", "Inter", sans-serif;
    font-weight: 600;
    line-height: 1.12;
    color: #effcff;
    font-size: 0.9rem;
  }

  .experience-panel,
  .experience-copy,
  .experience-main {
    width: min(100%, 58ch);
    margin-left: auto;
    margin-right: auto;
  }

  .experience-main {
    width: 100%;
  }

  @media (min-width: 1024px) {
    .experience-main {
      min-width: 0;
      padding-right: 0.5rem;
    }
  }

  .experience-card:hover {
    border-color: rgba(0, 245, 255, 0.42);
    box-shadow: 0 0 0 1px rgba(0, 245, 255, 0.08);
  }

  .experience-copy {
    display: grid;
    gap: 0.9rem;
  }

  .experience-paragraph {
    display: grid;
    grid-template-columns: 0.55rem minmax(0, 1fr);
    gap: 0.55rem;
    align-items: start;
  }

  .experience-bullet {
    width: 0.42rem;
    height: 0.42rem;
    margin-top: 0.6rem;
    border-radius: 999px;
    background: radial-gradient(circle at 35% 35%, #f4feff 0, rgba(132, 253, 255, 0.92) 32%, rgba(0, 245, 255, 0.76) 100%);
    box-shadow: 0 0 0 3px rgba(0, 245, 255, 0.04);
    flex-shrink: 0;
  }

  .experience-paragraph-text {
    margin: 0;
    text-wrap: pretty;
  }

  .experience-card:hover {
    border-color: rgba(0, 245, 255, 0.42);
  }

  .experience-card:hover h2 {
    color: #7cf7ff !important;
  }

  .experience-card:hover h3 {
    color: rgba(124, 247, 255, 0.76) !important;
  }

  .experience-card h2 {
    line-height: 1.06;
    letter-spacing: -0.05em;
    transition: color 0.3s ease;
  }

  .experience-card h3 {
    line-height: 1.15;
    margin-bottom: 0.6rem;
    transition: color 0.3s ease;
  }

  .tech-badge {
    list-style: none;
    border: 1px solid rgba(0, 245, 255, 0.35);
    background: rgba(0, 245, 255, 0.1);
    color: #d0f8ff;
    border-radius: 999px;
    padding: 0.32rem 0.68rem;
    font-size: 0.67rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 600;
    transition: border-color 0.2s ease, background 0.2s ease, color 0.2s ease;
  }

  .tech-badge:hover {
    border-color: rgba(0, 245, 255, 0.28);
    background: rgba(255, 255, 255, 0.04);
    color: #e7fbff;
  }

  @media (max-width: 1023px) {
    .experience-aside {
      margin-top: 1rem;
    }
  }
</style>
