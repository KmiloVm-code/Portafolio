---
import Github from "@/assets/svg/github.astro";
import Linkedin from "@/assets/svg/linkedin.astro";
import SectionHeader from "@/components/SectionHeader.astro";
---

<section id="contacto" class="py-16 md:py-32 bg-bg relative overflow-hidden">
  <div class="contact-bg" aria-hidden="true"></div>

  <div class="container mx-auto px-6 md:px-12 lg:px-16 max-w-7xl z-10 relative">
    <SectionHeader
      badge="Connect"
      title="Construyamos algo grande"
      subtitle="Estoy disponible para nuevos proyectos y colaboraciones estratégicas. Cuéntame tu visión y diseñemos la mejor forma de ejecutarla."
    />

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-14 lg:gap-20 items-start">
      <div class="prose prose-invert prose-a:no-underline mb-2 lg:mb-0 max-w-none">
        <p class="text-lg text-secondary">
          Ya sea para un producto desde cero, una evolución técnica o una mejora en
          rendimiento y arquitectura, puedo ayudarte a llevarlo a producción con
          foco en calidad y resultados.
        </p>

        <div class="mt-8 flex flex-col sm:flex-row gap-4">
          <a
            class="btn-line flex items-center justify-center gap-2 w-full hover:bg-accent-hover hover:text-bg"
            href="https://www.linkedin.com/in/andrescamilovelezmejia/"
            target="_blank"
            rel="noopener noreferrer"
          >
            <Linkedin />
            <span>LinkedIn</span>
          </a>

          <a
            class="btn-line flex items-center justify-center w-full gap-2 hover:bg-accent-hover hover:text-bg"
            href="https://github.com/KmiloVm-code"
            target="_blank"
            rel="noopener noreferrer"
          >
            <Github />
            <span>GitHub</span>
          </a>
        </div>
      </div>

      <div class="w-full">
        <div class="glass-card border-accent/25 p-6 sm:p-8 md:p-10 rounded-[1.6rem] sm:rounded-[2rem] relative overflow-hidden shadow-2xl min-h-104">
          <div class="absolute inset-0 bg-[radial-gradient(circle_at_90%_10%,rgba(0,188,212,0.18),transparent_45%)]" aria-hidden="true"></div>

          <div id="form-wrapper" data-visible="true" class="space-y-8 transition-all duration-500 ease-out relative z-10">
            <form id="contact-form" method="post" action="/api/contact" class="space-y-6">
              <div class="space-y-2">
                <label for="name" class="block text-sm font-medium text-primary">Nombre</label>
                <div class="relative">
                  <span class="input-icon" aria-hidden="true">@</span>
                  <input type="text" id="name" name="name" required class="input-premium" />
                </div>
              </div>

              <div class="space-y-2">
                <label for="email" class="block text-sm font-medium text-primary">Correo Electrónico</label>
                <div class="relative">
                  <span class="input-icon" aria-hidden="true">✉</span>
                  <input type="email" id="email" name="email" required class="input-premium" />
                </div>
              </div>

              <div class="space-y-2">
                <label for="message" class="block text-sm font-medium text-primary">Mensaje</label>
                <div class="relative">
                  <span class="input-icon top-4" aria-hidden="true">✎</span>
                  <textarea id="message" name="message" rows="4" required class="input-premium min-h-32"></textarea>
                </div>
              </div>

              <button
                type="submit"
                class="btn-primary w-full rounded-xl hover:-translate-y-0.5 transition-all duration-300 disabled:opacity-70 disabled:cursor-not-allowed disabled:hover:translate-y-0"
                aria-busy="false"
              >
                <span class="inline-flex items-center justify-center gap-3">
                  <span class="btn-label">Enviar Mensaje</span>
                  <span class="btn-loading hidden items-center gap-3">
                    <span class="spinner" aria-hidden="true"></span>
                    <span>Enviando...</span>
                  </span>
                </span>
              </button>
            </form>
          </div>

          <div id="success-screen" data-visible="false" class="absolute inset-0 px-5 flex flex-col items-center justify-center gap-6 text-center text-primary">
            <div class="flex h-24 w-24 items-center justify-center rounded-full border border-border-alt bg-border-alt/10 shadow-[0_0_25px_rgba(18,155,79,0.45)]">
              <svg class="h-12 w-12 text-green-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 6L9 17l-5-5"></path>
              </svg>
            </div>

            <div class="space-y-3">
              <h2 class="text-2xl sm:text-3xl font-bold text-primary">Mensaje recibido</h2>
              <p class="text-base sm:text-lg text-secondary">Analizaré tu propuesta y te contactaré lo antes posible.</p>
            </div>

            <button
              id="send-another"
              class="text-xs sm:text-sm font-semibold uppercase tracking-[0.16em] sm:tracking-[0.32em] text-accent hover:text-accent-hover hover:-translate-y-0.5 transition-all duration-300 cursor-pointer"
            >
              Enviar otro mensaje
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { initContactForm } from "@/scripts/contactForm";

  document.addEventListener("astro:page-load", initContactForm);
  document.addEventListener("astro:after-swap", initContactForm);
</script>

<style is:inline>
  .contact-bg {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 14% 24%, rgba(0, 245, 255, 0.16), transparent 32%),
      radial-gradient(circle at 88% 78%, rgba(102, 252, 255, 0.12), transparent 38%);
    transform: translateZ(0);
    animation: parallaxFloat 16s ease-in-out infinite;
    pointer-events: none;
  }

  .input-icon {
    position: absolute;
    left: 1rem;
    top: 50%;
    transform: translateY(-50%);
    font-size: 0.84rem;
    color: rgba(143, 224, 235, 0.7);
    pointer-events: none;
  }

  #form-wrapper,
  #success-screen {
    transition: opacity 0.5s ease, transform 0.5s ease;
  }

  #form-wrapper[data-visible="false"] {
    opacity: 0;
    transform: translateY(20px);
    pointer-events: none;
    visibility: hidden;
  }

  #form-wrapper[data-visible="true"] {
    opacity: 1;
    transform: translateY(0);
    visibility: visible;
    pointer-events: auto;
  }

  #success-screen {
    pointer-events: none;
    opacity: 0;
    transform: translateY(-20px);
    visibility: hidden;
  }

  #success-screen[data-visible="true"] {
    opacity: 1;
    transform: translateY(0);
    visibility: visible;
    pointer-events: auto;
  }

  #send-another[data-animate="true"] {
    animation: successButtonPop 0.55s ease;
  }

  .spinner {
    width: 18px;
    height: 18px;
    border-radius: 9999px;
    border: 2px solid rgba(0, 0, 0, 0.25);
    border-top-color: rgba(0, 0, 0, 0.85);
    animation: spin 0.8s linear infinite;
  }

  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }

  @keyframes successButtonPop {
    0% {
      opacity: 0;
      transform: translateY(8px) scale(0.95);
    }
    70% {
      opacity: 1;
      transform: translateY(0) scale(1.08);
    }
    100% {
      transform: translateY(0) scale(1);
    }
  }

  @keyframes parallaxFloat {
    0%,
    100% {
      transform: translate3d(0, 0, 0);
    }
    50% {
      transform: translate3d(-8px, -14px, 0);
    }
  }
</style>
