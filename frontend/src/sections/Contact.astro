---
import Github from "@/assets/svg/github.astro";
import Linkedin from "@/assets/svg/linkedin.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import ReadingCopy from "@/components/ReadingCopy.astro";
import Button from "@/components/Button.astro";
---

<section id="contacto" class="py-16 md:py-32 bg-bg relative">
  <div class="container mx-auto px-6 md:px-12 lg:px-16 max-w-7xl z-10 relative">
    <SectionHeader
      badge="Connect"
      title="Construyamos algo grande"
      subtitle="Estoy disponible para nuevos proyectos y colaboraciones estratégicas. Cuéntame tu visión y diseñemos la mejor forma de ejecutarla."
    />

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-14 lg:gap-20 items-start">
      <div class="mb-2 lg:mb-0 max-w-none">
        <ReadingCopy class="text-text-secondary max-w-[58ch]">
          Ya sea para un producto desde cero, una evolución técnica o una mejora
          en rendimiento y arquitectura, puedo ayudarte a llevarlo a producción
          con foco en calidad y resultados.
        </ReadingCopy>

        <div class="mt-8 flex flex-col sm:flex-row gap-4">
          <Button
            as="a"
            variant="line"
            class="w-full"
            href="https://www.linkedin.com/in/andrescamilovelezmejia/"
            target="_blank"
            rel="noopener noreferrer"
          >
            <Linkedin />
            <span>LinkedIn</span>
          </Button>

          <Button
            as="a"
            variant="line"
            class="w-full"
            href="https://github.com/KmiloVm-code"
            target="_blank"
            rel="noopener noreferrer"
          >
            <Github />
            <span>GitHub</span>
          </Button>
        </div>
      </div>

      <div class="w-full">
        <div
          class="glass-card p-6 sm:p-8 md:p-10 rounded-[1.5rem] relative min-h-112"
        >
          <div
            id="form-wrapper"
            data-visible="true"
            class="space-y-8 transition-all duration-500 ease-out relative z-10"
          >
            <form
              id="contact-form"
              method="post"
              action="/api/contact"
              class="space-y-6"
            >
              <div class="space-y-2">
                <label
                  for="name"
                  class="block text-sm font-medium text-text-primary"
                  >Nombre</label
                >
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  class="input-premium"
                />
              </div>

              <div class="space-y-2">
                <label
                  for="email"
                  class="block text-sm font-medium text-text-primary"
                  >Correo Electrónico</label
                >
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  class="input-premium"
                />
              </div>

              <div class="space-y-2">
                <label
                  for="message"
                  class="block text-sm font-medium text-text-primary"
                  >Mensaje</label
                >
                <textarea
                  id="message"
                  name="message"
                  rows="4"
                  required
                  class="input-premium min-h-32 resize-none"></textarea>
              </div>

              <button
                type="submit"
                class="ui-button ui-button-primary w-full rounded-xl disabled:opacity-70 disabled:cursor-not-allowed cursor-pointer"
                aria-busy="false"
              >
                <span class="inline-flex items-center justify-center gap-3">
                  <span class="btn-label cursor-pointer">Enviar Mensaje</span>
                  <span class="btn-loading hidden items-center gap-3">
                    <span class="spinner" aria-hidden="true"></span>
                    <span>Enviando...</span>
                  </span>
                </span>
              </button>
            </form>
          </div>

          <div
            id="success-screen"
            data-visible="false"
            class="absolute inset-0 px-5 flex flex-col items-center justify-center gap-6 text-center"
          >
            <div
              class="flex h-24 w-24 items-center justify-center rounded-full border border-success bg-success-muted"
            >
              <svg
                class="h-12 w-12 text-success"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M20 6L9 17l-5-5"></path>
              </svg>
            </div>

            <div class="space-y-3">
              <h2 class="text-2xl sm:text-3xl font-bold text-text-primary">
                Mensaje recibido
              </h2>
              <p class="text-base sm:text-lg text-text-secondary">
                Analizaré tu propuesta y te contactaré lo antes posible.
              </p>
            </div>

            <button
              id="send-another"
              class="text-xs sm:text-sm font-semibold uppercase tracking-[0.16em] text-accent hover:text-accent-hover transition-all cursor-pointer"
            >
              Enviar otro mensaje
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { initContactForm } from "@/scripts/contactForm";

  document.addEventListener("astro:page-load", initContactForm);
  document.addEventListener("astro:after-swap", initContactForm);
</script>

<style>
  #form-wrapper,
  #success-screen {
    transition:
      opacity 0.5s ease,
      transform 0.5s ease;
  }

  #form-wrapper[data-visible="false"] {
    opacity: 0;
    transform: translateY(20px);
    pointer-events: none;
    visibility: hidden;
  }

  #form-wrapper[data-visible="true"] {
    opacity: 1;
    transform: translateY(0);
    visibility: visible;
    pointer-events: auto;
  }

  #success-screen {
    pointer-events: none;
    opacity: 0;
    transform: translateY(-20px);
    visibility: hidden;
  }

  #success-screen[data-visible="true"] {
    opacity: 1;
    transform: translateY(0);
    visibility: visible;
    pointer-events: auto;
  }

  .spinner {
    width: 18px;
    height: 18px;
    border-radius: 9999px;
    border: 2px solid rgba(0, 0, 0, 0.25);
    border-top-color: rgba(0, 0, 0, 0.85);
    animation: spin 0.8s linear infinite;
  }

  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }
</style>
