---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";
import ArrowLeft from "@/assets/svg/arrow-left.astro";
import Images from "@/assets/svg/images.astro";
import ExternalLink from "@/assets/svg/external-link.astro";
import GitHubIcon from "@/assets/svg/github.astro";
import ReadingCopy from "@/components/ReadingCopy.astro";
import Chip from "@/components/Chip.astro";
import Button from "@/components/Button.astro";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((project) => ({
    params: { id: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const { data, slug } = project;
const {
  title,
  technologies,
  description,
  images,
  project_url,
  repository_url,
  challenges,
  result,
} = data;

const hasDetails = Boolean(challenges || result);
const projectImages = images && images.length > 0 ? images : ["/projects/default-project.webp"];

export const prerender = true;
---

<Layout title={`Proyecto - ${title}`}>
  <section class="project-page pb-20 bg-bg text-text-primary min-h-screen relative overflow-hidden">
    <header class="relative h-[48vh] min-h-[340px] md:h-[58vh] w-full mb-14 md:mb-16 overflow-hidden" transition:name={`image-${slug}`}>
      <div class="absolute top-4 left-4 md:top-8 md:left-8 z-30">
        <button id="back-button" class="back-btn group" type="button" aria-label="Volver al listado">
          <ArrowLeft size="16" class="transition-transform duration-300 group-hover:-translate-x-1" />
          Volver
        </button>
      </div>

      <img
        src={projectImages[0]}
        alt={title}
        class="w-full h-full object-cover object-top"
        loading="eager"
        decoding="async"
      />

      <div class="absolute inset-0 bg-linear-to-t from-bg via-bg/65 to-transparent"></div>
      <div class="absolute inset-0 bg-linear-to-r from-bg/70 via-transparent to-bg/55"></div>

      <article class="absolute bottom-0 left-0 w-full p-6 md:p-12">
        <div class="container mx-auto max-w-7xl">
          <span class="inline-flex items-center rounded-full border border-accent/40 bg-accent-subtle px-3 py-1 text-[11px] uppercase tracking-[0.18em] text-accent mb-4">
            Web Full Stack
          </span>
          <h1 transition:name={`title-${slug}`} class="text-3xl sm:text-4xl md:text-5xl font-bold text-text-primary leading-tight text-balance max-w-4xl">
            {title}
          </h1>
        </div>
      </article>
    </header>

    <div class="container mx-auto px-6 md:px-12 lg:px-16 max-w-7xl relative grid grid-cols-1 xl:grid-cols-[1fr_2fr] gap-8 xl:gap-10">
      <aside class="space-y-5 xl:sticky xl:top-28 self-start">
        <div class="glass-card p-5 md:p-6">
          <h2 class="text-base font-bold mb-4 flex items-center gap-2 uppercase tracking-[0.12em]">
            <Images size="18" class="text-accent" />
            Galería
          </h2>

          <div class="grid grid-cols-2 sm:grid-cols-3 xl:grid-cols-1 gap-3 md:gap-4">
            {
              projectImages.map((image, index) => (
                <div class={`gallery-item rounded-xl overflow-hidden border border-border ${index === 0 ? "col-span-2 sm:col-span-3 xl:col-span-1" : ""}`}>
                  <img
                    src={image}
                    alt={`${title} - vista ${index + 1}`}
                    class="w-full h-full rounded-xl transition-transform duration-500 hover:scale-105 aspect-video object-cover object-center"
                    loading="lazy"
                    decoding="async"
                  />
                </div>
              ))
            }
          </div>
        </div>

        <div class="glass-card p-5 md:p-6">
          <h2 class="text-base font-bold mb-4 uppercase tracking-[0.12em]">Tecnologías</h2>
          <ul class="flex flex-wrap gap-2">
            {technologies.map((tech) => (
              <Chip as="li">{tech}</Chip>
            ))}
          </ul>
        </div>
      </aside>

      <div class="space-y-8">
        <article class="card p-6 md:p-8">
          <h2 class="text-2xl md:text-3xl font-bold mb-4 text-accent">Descripción</h2>
          <ReadingCopy class="text-text-secondary mb-0 max-w-[68ch]">{description}</ReadingCopy>
        </article>

        {
          hasDetails && (
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <article class="card p-6 md:p-7">
                <h3 class="text-xl font-bold mb-3">Desafíos superados</h3>
                <ReadingCopy size="sm" class="text-text-secondary mb-0 max-w-[68ch] whitespace-pre-line">{challenges || "Sin detalles registrados."}</ReadingCopy>
              </article>

              <article class="card p-6 md:p-7">
                <h3 class="text-xl font-bold mb-3">Resultados obtenidos</h3>
                <ReadingCopy size="sm" class="text-text-secondary mb-0 max-w-[68ch] whitespace-pre-line">{result || "Sin detalles registrados."}</ReadingCopy>
              </article>
            </div>
          )
        }

        <div class="flex flex-col sm:flex-row gap-3 md:gap-4 pt-2">
          {
            project_url && (
              <Button as="a" variant="primary" href={project_url} class="flex-1 text-center gap-2">
                Ver Demo en Vivo
                <ExternalLink size="18" class="stroke-2" />
              </Button>
            )
          }
          {
            repository_url && (
              <Button as="a" variant="line" href={repository_url} class="flex-1 text-center gap-2">
                <GitHubIcon size="18" class="stroke-2" />
                Ver Código en GitHub
              </Button>
            )
          }
        </div>
      </div>
    </div>
  </section>

  <script>
    document.addEventListener("astro:page-load", () => {
      const backBtn = document.getElementById("back-button");
      if (!backBtn) return;
      backBtn.addEventListener("click", () => {
        history.back();
      });
    });
  </script>

  <style>
    .back-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      border: 1px solid var(--color-border);
      border-radius: 999px;
      padding: 0.55rem 0.95rem;
      font-size: 0.78rem;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      font-weight: 700;
      color: var(--color-text-secondary);
      background: rgba(12, 14, 20, 0.7);
      backdrop-filter: blur(8px);
      transition: border-color 0.2s ease, background 0.2s ease, transform 0.2s ease;
      cursor: pointer;
    }

    .back-btn:hover {
      border-color: var(--color-accent);
      color: var(--color-text-primary);
      background: var(--color-accent-subtle);
      transform: translateY(-1px);
    }

    .gallery-item {
      background: var(--color-bg-elevated);
      transition: border-color 0.2s ease, box-shadow 0.2s ease;
    }

    .gallery-item:hover {
      border-color: var(--color-border-hover);
      box-shadow: var(--shadow-lg);
    }

    @media (max-width: 639px) {
      .back-btn {
        font-size: 0.72rem;
        letter-spacing: 0.08em;
        padding: 0.48rem 0.8rem;
      }
    }
  </style>
</Layout>
