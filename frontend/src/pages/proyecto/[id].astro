---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";
import ArrowLeft from "@/assets/svg/arrow-left.astro";
import Images from "@/assets/svg/images.astro";
import ExternalLink from "@/assets/svg/external-link.astro";
import GitHubIcon from "@/assets/svg/github.astro";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((project) => ({
    params: { id: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const { data, slug } = project;
const {
  title,
  technologies,
  description,
  images,
  project_url,
  repository_url,
  challenges,
  result,
} = data;

const hasDetails = Boolean(challenges || result);
const projectImages = images && images.length > 0 ? images : ["/projects/default-project.webp"];

export const prerender = true;
---

<Layout title={`Proyecto - ${title}`}>
  <section class="project-page pb-20 bg-bg text-primary min-h-screen relative overflow-hidden">
    <div class="project-bg" aria-hidden="true"></div>

    <header class="relative h-[48vh] min-h-[340px] md:h-[58vh] w-full mb-14 md:mb-16 overflow-hidden" transition:name={`image-${slug}`}>
      <div class="absolute top-4 left-4 md:top-8 md:left-8 z-30">
        <button
          id="back-button"
          class="back-btn group"
          type="button"
          aria-label="Volver al listado"
        >
          <ArrowLeft size="16" class="transition-transform duration-300 group-hover:-translate-x-1" />
          Volver
        </button>
      </div>

      <img
        src={projectImages[0]}
        alt={title}
        class="w-full h-full object-cover object-top"
        loading="eager"
        decoding="async"
      />

      <div class="absolute inset-0 bg-linear-to-t from-bg via-bg/65 to-transparent"></div>
      <div class="absolute inset-0 bg-linear-to-r from-bg/70 via-transparent to-bg/55"></div>

      <article class="absolute bottom-0 left-0 w-full p-6 md:p-12">
        <div class="container mx-auto max-w-7xl">
          <span class="inline-flex items-center rounded-full border border-accent/40 bg-accent/12 px-3 py-1 text-[11px] uppercase tracking-[0.18em] text-accent mb-4">
            Web Full Stack
          </span>
          <h1 transition:name={`title-${slug}`} class="text-3xl sm:text-4xl md:text-5xl font-bold text-primary leading-tight text-balance max-w-4xl">
            {title}
          </h1>
        </div>
      </article>
    </header>

    <div class="container mx-auto px-6 md:px-12 lg:px-16 max-w-7xl relative grid grid-cols-1 xl:grid-cols-[1fr_2fr] gap-8 xl:gap-10">
      <aside class="space-y-5 xl:sticky xl:top-28 self-start">
        <div class="glass-card p-5 md:p-6">
          <h2 class="text-base font-bold mb-4 text-primary flex items-center gap-2 uppercase tracking-[0.12em]">
            <Images size="18" class="text-accent" />
            Galería
          </h2>

          <div class="grid grid-cols-2 sm:grid-cols-3 xl:grid-cols-1 gap-3 md:gap-4">
            {
              projectImages.map((image, index) => (
                <div class={`gallery-item rounded-xl overflow-hidden border border-border/40 ${index === 0 ? "col-span-2 sm:col-span-3 xl:col-span-1" : ""}`}>
                  <img
                    src={image}
                    alt={`${title} - vista ${index + 1}`}
                    class="w-full h-full rounded-xl transition-transform duration-500 hover:scale-105 aspect-video object-cover object-center"
                    loading="lazy"
                    decoding="async"
                  />
                </div>
              ))
            }
          </div>
        </div>

        <div class="glass-card p-5 md:p-6">
          <h2 class="text-base font-bold mb-4 text-primary uppercase tracking-[0.12em]">Tecnologías</h2>
          <ul class="flex flex-wrap gap-2">
            {technologies.map((tech) => (
              <li class="tech-chip">{tech}</li>
            ))}
          </ul>
        </div>
      </aside>

      <div class="space-y-8">
        <article class="glass-card p-6 md:p-8 prose prose-invert max-w-none">
          <h2 class="text-2xl md:text-3xl font-bold mb-4 text-shimmer">Descripción</h2>
          <p class="text-base md:text-lg text-secondary mb-0 text-pretty">{description}</p>
        </article>

        {
          hasDetails && (
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <article class="glass-card p-6 md:p-7 prose prose-invert max-w-none">
                <h3 class="text-xl font-bold mb-3">Desafíos superados</h3>
                <p class="text-sm md:text-base whitespace-pre-line text-secondary mb-0">{challenges || "Sin detalles registrados."}</p>
              </article>

              <article class="glass-card p-6 md:p-7 prose prose-invert max-w-none">
                <h3 class="text-xl font-bold mb-3">Resultados obtenidos</h3>
                <p class="text-sm md:text-base whitespace-pre-line text-secondary mb-0">{result || "Sin detalles registrados."}</p>
              </article>
            </div>
          )
        }

        <div class="flex flex-col sm:flex-row gap-3 md:gap-4 pt-2">
          {
            project_url && (
              <a
                href={project_url}
                target="_blank"
                rel="noopener noreferrer"
                class="btn-primary flex-1 text-center inline-flex justify-center items-center gap-2"
              >
                Ver Demo en Vivo
                <ExternalLink size="18" class="stroke-2" />
              </a>
            )
          }
          {
            repository_url && (
              <a
                href={repository_url}
                target="_blank"
                rel="noopener noreferrer"
                class="btn-line flex-1 text-center inline-flex justify-center items-center gap-2"
              >
                <GitHubIcon size="18" class="stroke-2" />
                Ver Código en GitHub
              </a>
            )
          }
        </div>
      </div>
    </div>
  </section>

  <script>
    document.addEventListener("astro:page-load", () => {
      const backBtn = document.getElementById("back-button");
      if (!backBtn) return;
      backBtn.addEventListener("click", () => {
        history.back();
      });
    });
  </script>

  <style>
    .project-bg {
      position: absolute;
      inset: 0;
      pointer-events: none;
      background: radial-gradient(circle at 8% 14%, rgba(0, 188, 212, 0.16), transparent 30%),
        radial-gradient(circle at 86% 70%, rgba(0, 188, 212, 0.1), transparent 34%);
    }

    .back-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      border: 1px solid rgba(0, 188, 212, 0.26);
      border-radius: 999px;
      padding: 0.55rem 0.95rem;
      font-size: 0.78rem;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      font-weight: 700;
      color: #d6f8ff;
      background: rgba(4, 10, 20, 0.5);
      backdrop-filter: blur(8px);
      transition: border-color 0.3s ease, background 0.3s ease, transform 0.3s ease;
      cursor: pointer;
    }

    .back-btn:hover {
      border-color: rgba(0, 188, 212, 0.65);
      background: rgba(0, 188, 212, 0.12);
      transform: translateY(-1px);
    }

    .gallery-item {
      background: rgba(4, 10, 20, 0.45);
      transition: border-color 0.3s ease, box-shadow 0.3s ease;
    }

    .gallery-item:hover {
      border-color: rgba(0, 188, 212, 0.55);
      box-shadow: 0 14px 26px rgba(0, 0, 0, 0.35), 0 0 18px rgba(0, 188, 212, 0.15);
    }

    .tech-chip {
      list-style: none;
      border: 1px solid rgba(0, 188, 212, 0.36);
      background: rgba(0, 188, 212, 0.1);
      color: #cdf7ff;
      border-radius: 999px;
      padding: 0.34rem 0.72rem;
      font-size: 0.69rem;
      line-height: 1.1;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }

    @media (max-width: 639px) {
      .back-btn {
        font-size: 0.72rem;
        letter-spacing: 0.08em;
        padding: 0.48rem 0.8rem;
      }
    }
  </style>
</Layout>
