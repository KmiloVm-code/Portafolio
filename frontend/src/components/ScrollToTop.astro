<button
  id="scroll-top"
  type="button"
  aria-label="Volver arriba"
  class="fixed right-5 bottom-5 md:right-8 md:bottom-8 z-40 h-12 w-12 rounded-full border border-border bg-bg-elevated text-text-secondary backdrop-blur-lg opacity-0 translate-y-4 pointer-events-none transition-all duration-300 hover:border-accent hover:text-accent hover:-translate-y-1"
>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    class="mx-auto h-5 w-5"
    aria-hidden="true"
  >
    <path d="m18 15-6-6-6 6"></path>
  </svg>
</button>

<script>
  function initScrollTop() {
    const button = document.getElementById("scroll-top") as HTMLButtonElement | null;
    if (!button || button.dataset.ready === "true") return;
    button.dataset.ready = "true";

    const toggleButton = () => {
      const shouldShow = window.scrollY > 480;
      button.classList.toggle("opacity-0", !shouldShow);
      button.classList.toggle("translate-y-4", !shouldShow);
      button.classList.toggle("pointer-events-none", !shouldShow);
    };

    button.addEventListener("click", () => {
      window.scrollTo({ top: 0, behavior: "smooth" });
    });

    window.addEventListener("scroll", toggleButton, { passive: true });
    toggleButton();

    document.addEventListener(
      "astro:before-swap",
      () => {
        window.removeEventListener("scroll", toggleButton);
      },
      { once: true }
    );
  }

  document.addEventListener("astro:page-load", initScrollTop);
</script>
