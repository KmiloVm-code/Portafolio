---
interface Props {
  as?: "a" | "button";
  variant?: "primary" | "line";
  href?: string;
  type?: "button" | "submit" | "reset";
  target?: "_blank" | "_self" | "_parent" | "_top";
  rel?: string;
  class?: string;
}

const {
  as = "a",
  variant = "primary",
  href,
  type = "button",
  target,
  rel,
  class: className = "",
  ...rest
} = Astro.props as Props & Record<string, unknown>;

const variantClass =
  variant === "line" ? "ui-button-line" : "ui-button-primary";
const sizeClass = "px-6 py-3 sm:px-6 sm:py-3.5";
---

{
  as === "button" ? (
    <button
      type={type}
      class={`ui-button ${sizeClass} ${variantClass} ${className}`.trim()}
      {...rest}
    >
      <slot />
    </button>
  ) : (
    <a
      href={href}
      class={`ui-button ${sizeClass} ${variantClass} ${className}`.trim()}
      {...rest}
      target={target}
      rel={rel || (target === "_blank" ? "noopener noreferrer" : undefined)}
    >
      <slot />
    </a>
  )
}
